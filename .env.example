# ============================================================
# Triagista — Environment Variables
# ============================================================
# Copy this file to .env and fill in your API keys:
#   cp .env.example .env
# Then start with:
#   docker compose up --build -d
# ============================================================

# === Triage Engine Selection ===
# Choose which engine to use by default: anthropic, langchain, or managed
TRIAGE_PROVIDER=anthropic

# === Engine 1: Premium (Anthropic SDK) ===
# REQUIRED for Premium engine. Get key at: https://console.anthropic.com/
# Uses Claude Haiku 4.5 with structured tool_use.
ANTHROPIC_API_KEY=sk-ant-xxx

# === Engine 2: Basic (LangChain + Free Models) ===
# Get a FREE Gemini key (no credit card): https://aistudio.google.com/apikey
GOOGLE_API_KEY=
# Optional fallback — FREE Groq key (no credit card): https://console.groq.com
GROQ_API_KEY=

# === Engine 3: Experimental (Managed Agents) ===
# Requires Anthropic Managed Agents beta access.
# Create agent + environment in Claude Console → Managed Agents.
# See docs/managed-agent-setup.md for the agent YAML config.
MANAGED_AGENT_ID=
MANAGED_ENVIRONMENT_ID=

# === Database ===
# No changes needed — these match the docker-compose.yml defaults.
DATABASE_URL=postgresql+asyncpg://sre:sre_password@postgres:5432/sre_triage
POSTGRES_USER=sre
POSTGRES_PASSWORD=sre_password
POSTGRES_DB=sre_triage

# === Redis ===
REDIS_URL=redis://redis:6379/0

# === Langfuse (LLM Observability) ===
# Keys are AUTO-CONFIGURED on first startup in development mode.
# Dashboard: http://localhost:3100
# Login: admin@sre-triage.local / admin123
# No manual setup needed — leave these empty.
LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_HOST=http://langfuse:3000

# Langfuse's own database (internal, no changes needed)
LANGFUSE_DATABASE_URL=postgresql://langfuse:langfuse_password@langfuse-db:5432/langfuse
LANGFUSE_POSTGRES_USER=langfuse
LANGFUSE_POSTGRES_PASSWORD=langfuse_password
LANGFUSE_POSTGRES_DB=langfuse

# === OpenTelemetry ===
OTEL_SERVICE_NAME=sre-triage-agent
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# === App Settings ===
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
UPLOAD_DIR=/app/uploads
MAX_UPLOAD_SIZE_MB=5

# === E-Commerce Codebase ===
# Solidus repo is cloned automatically at container startup.
ECOMMERCE_REPO_PATH=/app/ecommerce-repo
